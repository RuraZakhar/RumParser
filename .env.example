FIRECRAWL_API_KEY=put_your_new_key_here
# Maximum number of RumRatings pages scraped in one run.
MAX_RUM_RATINGS_PAGES=25
# Maximum number of Rum Howler products fetched in one run.
MAX_HOWLER_PRODUCTS=500
# Maximum number of previously unpriced products sent to Silpo lookup per run.
MAX_SILPO_LOOKUPS_PER_RUN=25
